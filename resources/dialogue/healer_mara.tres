[sub_resource type="Resource" id="Resource_5b1ju"]
script = ExtResource("1_gqfis")
speaker = "Mara"
text = "Traveller! Thank the stars someone's come. The Quiet Sickness is spreading — cattle dropping, dogs going blind, even the wild rabbits are wasting away. I'm running out of remedies and running out of time. Can you help?"
choices = Array[Resource]([SubResource("Resource_fd1ix"), SubResource("Resource_11g8s"), SubResource("Resource_uuyc4")])
condition_flag = ""
condition_flag_false = ""

